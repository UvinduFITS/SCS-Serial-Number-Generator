# Supabase project URL — found in: Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) key — found in: Settings → API → Project API keys → anon public
# This is a JWT that starts with "eyJ..." and is safe to expose in the browser.
# NEVER use the service_role key here — that one must stay server-side only.
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
